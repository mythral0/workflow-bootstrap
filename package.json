{
  "name": "workflow-bootstrap",
  "version": "0.4.0",
  "private": true,
  "description": "Generate tested GitHub Actions and GitOps workflows from an existing repository",
  "type": "module",
  "scripts": {
    "prebuild": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "tsc -p tsconfig.json && esbuild src/cli.ts --bundle --platform=node --format=cjs --target=node20 --outfile=bin/workflow-bootstrap.cjs",
    "postbuild": "node -e \"require('node:fs').chmodSync('bin/workflow-bootstrap.cjs', 0o755)\"",
    "check": "npm run build && npm run test",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "github-actions",
    "gitops",
    "workflow",
    "bootstrap",
    "docker",
    "helm"
  ],
  "author": "mythral0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mythral0/workflow-bootstrap.git"
  },
  "bugs": {
    "url": "https://github.com/mythral0/workflow-bootstrap/issues"
  },
  "homepage": "https://github.com/mythral0/workflow-bootstrap#readme",
  "dependencies": {
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/node": "^24.13.3",
    "esbuild": "^0.28.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
